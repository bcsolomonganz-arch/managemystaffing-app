# ManageMyStaffing — environment template
# Copy to .env (LOCAL ONLY — never commit). On Azure App Service, these come from Key Vault references.

# Core
PORT=3002
NODE_ENV=development
APP_URL=https://www.managemystaffing.com

# Required secrets (server refuses to start without them)
JWT_SECRET=<48+ random bytes, use base64: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))">
DATA_ENCRYPTION_KEY=<32-byte hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
AUDIT_HMAC_KEY=<32-byte hex>

# File paths
DATA_FILE=C:\ProgramData\ManageMyStaffing\mms-data.json
AUDIT_LOG_FILE=C:\ProgramData\ManageMyStaffing\mms-audit.log

# Azure Communication Services
ACS_CONNECTION_STRING=endpoint=https://...;accesskey=...
ACS_FROM_EMAIL=noreply@managemystaffing.com
ACS_FROM_PHONE=+18556682831

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# PointClickCare (optional)
PCC_CLIENT_ID=
PCC_CLIENT_SECRET=
PCC_FACILITY_ID=
PCC_ORG_UUID=
